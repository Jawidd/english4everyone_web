FROM node:22-alpine

WORKDIR /studio

COPY package.json ./
RUN npm install

COPY . .

# Build the studio before deploying
RUN npm run build

# SANITY_AUTH_TOKEN must be passed at runtime:
#   docker run -e SANITY_AUTH_TOKEN=<your_token> <image>
# Get your token: https://sanity.io/manage → project → API → Tokens → Add token (Deploy Studio)
CMD ["npm", "run", "deploy"]
